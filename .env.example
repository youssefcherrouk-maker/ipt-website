# ============================================================
# IPTV Premium - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ---- Backend Configuration ----
NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info

# ---- Database (PostgreSQL) ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=iptv_premium
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# ---- PayPal API ----
# Get these from https://developer.paypal.com/dashboard/applications
# Use sandbox credentials for testing, live for production
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
# For production: https://api-m.paypal.com
# Webhook ID from PayPal Developer Dashboard (under Webhooks)
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id_here

# ---- SMTP / Email (Nodemailer) ----
# Gmail example (use app password for Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=noreply@iptvpremium.com
ADMIN_EMAIL=admin@iptvpremium.com

# ---- Frontend (Next.js) ----
# These are prefixed with NEXT_PUBLIC_ so they are exposed to the browser
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id_here
